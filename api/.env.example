# Runtime
NODE_ENV=development
PORT=8000

# URLs
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000
COOKIE_DOMAIN=

# Database (required for Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public

# Security
JWT_SECRET=replace_with_a_long_random_secret
WEBHOOK_SECRET=codereview_webhook_secret_dev

# Google OAuth (required only if using Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# GitHub OAuth (required only if using GitHub integration)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/integrations/github/callback

# AI provider
GROQ_API_KEY=
